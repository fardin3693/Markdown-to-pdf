# Server Configuration
PORT=3001
NODE_ENV=production

# Security
# In production, change this to your actual frontend domain
FRONTEND_URL=https://pdfwiser.com

# Python executable path – required for pdf-to-word, pdf-to-ppt, pdf-to-excel tools.
# Set this to the full path of your Python 3 interpreter on the production server.
# Example (Linux): PYTHON_PATH=/usr/bin/python3
PYTHON_PATH=

