# Server Configuration
PORT=3001
NODE_ENV=development

# CORS / Frontend URL
FRONTEND_URL=http://localhost:3000

# Runtime dependency overrides (optional)
# Linux example:
# LIBREOFFICE_PATH=/usr/bin/soffice
# PYTHON_PATH=/usr/bin/python3
# Windows example:
# LIBREOFFICE_PATH=C:\\Program Files\\LibreOffice\\program\\soffice.exe
# PYTHON_PATH=C:\\Users\\your-user\\AppData\\Local\\Programs\\Python\\Python314\\python.exe
LIBREOFFICE_PATH=
PYTHON_PATH=

