# Server Configuration
PORT=3001
NODE_ENV=development

# CORS / Frontend URL
FRONTEND_URL=http://localhost:3000

# Python executable path – required for pdf-to-word, pdf-to-ppt, pdf-to-excel tools.
# Set this to the full path of your Python 3 interpreter.
# Example (Windows): PYTHON_PATH=C:\Python311\python.exe
# Example (Linux):   PYTHON_PATH=/usr/bin/python3
PYTHON_PATH=

